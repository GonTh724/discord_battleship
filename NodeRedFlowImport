        "format": "<template>\n  <div class=\"battleship-dashboard-wrapper\">\n    <v-card class=\"pa-4 mx-auto\" max-width=\"900\" variant=\"elevated\">\n      <v-card-title class=\"d-flex align-center justify-space-between flex-wrap gap-2\">\n        <span class=\"text-h5 font-weight-bold\">🚢 Battleship Command Center</span>\n        <v-chip :color=\"gameStatusColor\" size=\"small\" variant=\"flat\" class=\"text-uppercase\">\n          {{ state.status || 'No Active Game' }}\n        </v-chip>\n      </v-card-title>\n      \n      <v-card-text>\n        <!-- Game Controller Actions -->\n        <div class=\"mb-4 d-flex gap-2\">\n          <v-btn color=\"primary\" @click=\"startGame\" :disabled=\"state.status === 'active'\">\n            New Match\n          </v-btn>\n          <v-btn color=\"error\" variant=\"outlined\" @click=\"forfeitGame\" :disabled=\"state.status !== 'active'\">\n            Forfeit Match\n          </v-btn>\n        </div>\n\n        <!-- Turn / Move Report Alert -->\n        <v-alert v-if=\"state.lastMoveReport\" type=\"info\" variant=\"tonal\" class=\"mb-4\">\n          {{ state.lastMoveReport }}\n        </v-alert>\n\n        <!-- Combined Grid Layout -->\n        <v-row v-if=\"state.status === 'active' || state.status === 'victory' || state.status === 'defeat'\">\n          \n          <!-- TARGET BOARD -->\n          <v-col cols=\"12\" md=\"6\" class=\"d-flex flex-column align-center\">\n            <div class=\"text-subtitle-1 font-weight-bold mb-2\">🎯 Enemy Target Grid</div>\n            <div class=\"grid-container\">\n              <div class=\"grid-header-row\">\n                <div class=\"grid-corner\"></div>\n                <div v-for=\"col in 8\" :key=\"col\" class=\"grid-header-cell\">{{ col }}</div>\n              </div>\n              <div v-for=\"(row, rIdx) in state.aiGrid\" :key=\"rIdx\" class=\"grid-row\">\n                <div class=\"grid-row-header\">{{ getRowLabel(rIdx) }}</div>\n                <button \n                  v-for=\"(cell, cIdx) in row\" \n                  :key=\"cIdx\"\n                  class=\"grid-cell\"\n                  :class=\"getCellClass(cell, true)\"\n                  :disabled=\"state.status !== 'active' || cell === 'X' || cell === 'O'\"\n                  @click=\"fireCoordinate(rIdx, cIdx)\"\n                >\n                  <span v-if=\"cell === 'X'\">💥</span>\n                  <span v-else-if=\"cell === 'O'\">⚪</span>\n                </button>\n              </div>\n            </div>\n          </v-col>\n\n          <!-- DEFENDING BOARD -->\n          <v-col cols=\"12\" md=\"6\" class=\"d-flex flex-column align-center\">\n            <div class=\"text-subtitle-1 font-weight-bold mb-2\">🛡️ Your Fleet Grid</div>\n            <div class=\"grid-container\">\n              <div class=\"grid-header-row\">\n                <div class=\"grid-corner\"></div>\n                <div v-for=\"col in 8\" :key=\"col\" class=\"grid-header-cell\">{{ col }}</div>\n              </div>\n              <div v-for=\"(row, rIdx) in state.playerGrid\" :key=\"rIdx\" class=\"grid-row\">\n                <div class=\"grid-row-header\">{{ getRowLabel(rIdx) }}</div>\n                <div \n                  v-for=\"(cell, cIdx) in row\" \n                  :key=\"cIdx\"\n                  class=\"grid-cell locked\"\n                  :class=\"getCellClass(cell, false)\"\n                >\n                  <span v-if=\"cell === 'S'\">🚢</span>\n                  <span v-else-if=\"cell === 'X'\">💥</span>\n                  <span v-else-if=\"cell === 'O'\">⚪</span>\n                </div>\n              </div>\n            </div>\n          </v-col>\n        </v-row>\n        \n        <!-- Terminal Screen Overlays -->\n        <v-sheet v-if=\"state.status === 'victory'\" class=\"pa-4 text-center bg-green-lighten-4 rounded mt-4\">\n          <div class=\"text-h5 text-green-darken-3 mb-1\">🎉 VICTORY! 🎉</div>\n          <div class=\"text-body-2 text-green-darken-4\">All enemy ships have been eliminated!</div>\n        </v-sheet>\n        \n        <v-sheet v-if=\"state.status === 'defeat'\" class=\"pa-4 text-center bg-red-lighten-4 rounded mt-4\">\n          <div class=\"text-h5 text-red-darken-3 mb-1\">💀 DEFEAT! 💀</div>\n          <div class=\"text-body-2 text-red-darken-4\">Your fleet has been completely destroyed.</div>\n        </v-sheet>\n      </v-card-text>\n    </v-card>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      state: {\n        status: 'inactive',\n        playerGrid: [],\n        aiGrid: [],\n        lastMoveReport: ''\n      }\n    };\n  },\n  computed: {\n    gameStatusColor() {\n      if (this.state.status === 'active') return 'green';\n      if (this.state.status === 'victory') return 'teal';\n      if (this.state.status === 'defeat') return 'red';\n      return 'grey';\n    }\n  },\n  methods: {\n    startGame() {\n      this.send({\n        payload: \"!bs start\",\n        channel: \"dashboard\",\n        author: { id: \"dashboard\", username: \"Dashboard User\" }\n      });\n    },\n    forfeitGame() {\n      this.send({\n        payload: \"!bs forfeit\",\n        channel: \"dashboard\",\n        author: { id: \"dashboard\", username: \"Dashboard User\" }\n      });\n    },\n    fireCoordinate(r, c) {\n      const rowChar = String.fromCharCode(65 + r);\n      const colNum = c + 1;\n      this.send({\n        payload: \"!bs fire \" + rowChar + colNum,\n        channel: \"dashboard\",\n        author: { id: \"dashboard\", username: \"Dashboard User\" }\n      });\n    },\n    getRowLabel(idx) {\n      return String.fromCharCode(65 + idx);\n    },\n    getCellClass(cell, isEnemy) {\n      if (cell === '~') return 'cell-water';\n      if (cell === 'S') return isEnemy ? 'cell-water' : 'cell-ship';\n      if (cell === 'X') return 'cell-hit';\n      if (cell === 'O') return 'cell-miss';\n      return '';\n    }\n  },\n  mounted() {\n    // Synchronize updates sent from the Engine function node\n    this.$socket.on('msg-input:' + this.id, (msg) => {\n      if (msg && msg.payload && typeof msg.payload === 'object') {\n        this.state = msg.payload;\n      }\n    });\n    // Fetch the current session state on refresh\n    this.send({\n      payload: \"!bs board\",\n      channel: \"dashboard\",\n      author: { id: \"dashboard\", username: \"Dashboard User\" }\n    });\n  }\n}\n</script>\n\n<style>\n.grid-container {\n  display: inline-block;\n  background-color: #2c2c2c;\n  padding: 8px;\n  border-radius: 8px;\n  user-select: none;\n}\n.grid-header-row {\n  display: flex;\n}\n.grid-corner {\n  width: 32px;\n  height: 32px;\n}\n.grid-header-cell {\n  width: 36px;\n  height: 32px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  font-weight: bold;\n  font-size: 0.9rem;\n}\n.grid-row {\n  display: flex;\n  align-items: center;\n}\n.grid-row-header {\n  width: 32px;\n  height: 36px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: #fff;\n  font-weight: bold;\n  font-size: 0.9rem;\n}\n.grid-cell {\n  width: 32px;\n  height: 32px;\n  margin: 2px;\n  border-radius: 4px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n  transition: background-color 0.2s, transform 0.1s;\n  border: none;\n}\n.grid-cell:hover:not(:disabled) {\n  transform: scale(1.1);\n  filter: brightness(1.2);\n}\n.grid-cell.locked {\n  cursor: default;\n}\n.cell-water {\n  background-color: #1e88e5 !important;\n}\n.cell-ship {\n  background-color: #757575 !important;\n}\n.cell-hit {\n  background-color: #e53935 !important;\n}\n.cell-miss {\n  background-color: #b0bec5 !important;\n}\n.gap-2 {\n  gap: 8px;\n}\n</style>",
